# Copie para ".env.local" e preencha com os dados do seu projeto Sanity.
# Estes valores NÃO são secretos (ficam visíveis no site), mas mantemos em env
# para facilitar a configuração no Vercel.
#
# Enquanto estiverem vazios, o site usa conteúdo de exemplo (fallback) — nada quebra.
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
